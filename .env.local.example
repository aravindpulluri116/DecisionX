# Supabase local development
# Run: supabase start
# Then copy values from: supabase status

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# IMPORTANT: Use the JWT anon key from `supabase status` (starts with eyJ…)
# Do NOT use sb_publishable_* here — that causes 401 on REST API locally.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Server-only — used by /api/projects for writes (from `supabase status` → SERVICE_ROLE_KEY)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Claude multi-agent intelligence (server-only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — override default public Overpass/Nominatim endpoints
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OPENFREEMAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
