# Supabase — use cloud project (recommended) or local `supabase start`
# Cloud dashboard: https://supabase.com/dashboard/project/tsoyxmxkiaxbxrtzvjii

NEXT_PUBLIC_SUPABASE_URL=https://tsoyxmxkiaxbxrtzvjii.supabase.co

# JWT anon key from Dashboard → Settings → API (starts with eyJ…)
# Do NOT use sb_publishable_* for NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-key

# Server-only — service_role from Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Local development (optional) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<from supabase status>

# Claude multi-agent intelligence (server-only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — override default public Overpass/Nominatim endpoints
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OPENFREEMAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_OPENFREEMAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
